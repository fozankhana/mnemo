{
  "name": "mnemo-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "Mnemo — a user-owned memory layer for AI tools, with consent and audit.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm build && node --test \"packages/core/test/*.test.ts\"",
    "test:integration": "pnpm build && node --test \"packages/mcp/test/*.test.ts\"",
    "test:all": "pnpm build && node --test \"packages/*/test/*.test.ts\"",
    "mnemo": "node packages/cli/dist/index.js",
    "dashboard": "node packages/cli/dist/index.js dashboard"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "typescript": "^5.7.3"
  }
}
